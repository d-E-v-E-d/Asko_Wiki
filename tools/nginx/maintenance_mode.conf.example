# Example snippet for the Arbeitsanweisung nginx server block.
# Adjust SERVER_NAME / paths / allowlist IPs to your environment.
#
# Usage:
# 1. Copy maintenance.html to a static location on the server, for example:
#      /srv/arbeitsanweisung/maintenance/maintenance.html
# 2. Include this logic inside the HTTPS server block for docs.asko24.at
# 3. Replace the allow entries with your own office/VPN IP address(es)
# 4. Activate maintenance mode with:
#      sudo touch /srv/arbeitsanweisung/maintenance/maintenance.on
# 5. Deactivate maintenance mode with:
#      sudo rm -f /srv/arbeitsanweisung/maintenance/maintenance.on

# Allowlist for testing during maintenance.
geo $aw_maintenance_bypass {
    default 0;
    127.0.0.1/32 1;
    ::1/128 1;
    # Replace with your own fixed public/VPN IPs:
    # 203.0.113.10/32 1;
    # 198.51.100.0/24 1;
}

map "$aw_maintenance_bypass:$aw_maintenance_flag" $aw_maintenance_block {
    default 0;
    "0:1" 1;
}

server {
    listen 443 ssl http2;
    server_name docs.asko24.at;

    # Flag file: exists => maintenance mode active
    set $aw_maintenance_flag 0;
    if (-f /srv/arbeitsanweisung/maintenance/maintenance.on) {
        set $aw_maintenance_flag 1;
    }

    root /srv/arbeitsanweisung/maintenance;
    error_page 503 @aw_maintenance;

    location = /maintenance.html {
        internal;
    }

    location @aw_maintenance {
        rewrite ^ /maintenance.html break;
    }

    location / {
        if ($aw_maintenance_block) {
            return 503;
        }

        proxy_pass http://127.0.0.1:8010;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
